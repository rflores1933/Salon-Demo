<%- include('partials/header', { title: 'The Gymnasium — Salon' }) %>

<header class="gym-header">
  <div>
    <h1>The Gymnasium</h1>
    <p class="welcome">Welcome, <%= username %>.</p>
  </div>
  <form method="POST" action="/logout" class="logout-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit" class="ghost">Log out</button>
  </form>
</header>

<% if (error) { %>
  <div class="error" role="alert"><%= error %></div>
<% } %>

<section class="my-intention">
  <h2>Your intention</h2>

  <% if (myIntention) { %>
    <blockquote class="active-intention"><%= myIntention.body %></blockquote>

    <form method="POST" action="/gymnasium/intentions/clear">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="ghost">Clear and start fresh</button>
    </form>
  <% } else { %>
    <form method="POST" action="/gymnasium/intentions" class="intention-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label for="body">What are you working on?</label>
      <input type="text" id="body" name="body" maxlength="140" required
             placeholder="Sitting with a hard problem" autofocus
             autocomplete="off">
      <button type="submit">Set intention</button>
    </form>
  <% } %>
</section>

<section class="others">
  <h2>Others in the gymnasium</h2>

  <% const others = intentions.filter(function(i) { return i.username !== username; }); %>

  <% if (others.length === 0) { %>
    <p class="empty">It's quiet right now. You're alone in the gymnasium.</p>
  <% } else { %>
    <ul class="intention-list">
      <% others.forEach(function(i) { %>
        <li>
          <strong><%= i.username %></strong>
          <span class="intention-body"><%= i.body %></span>
        </li>
      <% }); %>
    </ul>
  <% } %>
</section>

<%- include('partials/footer') %>