<%- include('partials/header', { title: 'The Gymnasium — Salon', bodyClass: 'gym' }) %>

<header class="gym-header">
  <h1>Gymnasium</h1>
  <form method="POST" action="/logout" class="logout-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit" class="ghost">Log out</button>
  </form>
</header>

<% if (error) { %>
  <div class="error" role="alert"><%= error %></div>
<% } %>

<section class="my-intention">
  <% if (myIntention) { %>
    <blockquote class="active-intention"><%= myIntention.body %></blockquote>
    <form method="POST" action="/gymnasium/intentions/clear" class="intention-clear">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="ghost">Clear</button>
    </form>
  <% } else { %>
    <form method="POST" action="/gymnasium/intentions" class="intention-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="text" id="body" name="body" maxlength="140" required
             placeholder="What are you working on?" autofocus
             autocomplete="off">
      <button type="submit">Set</button>
    </form>
  <% } %>
</section>

<section class="whiteboard">
  <form method="POST" action="/gymnasium/whiteboard">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <textarea name="body" maxlength="5000" placeholder="A space to think."><%= whiteboard %></textarea>
    <button type="submit" class="ghost">Save</button>
  </form>
</section>

<%- include('partials/footer') %>